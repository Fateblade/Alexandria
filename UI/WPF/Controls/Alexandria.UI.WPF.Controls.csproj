<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>Alexandria.UI.WPF.Controls</AssemblyName>
    <RootNamespace>Fateblade.Alexandria.UI.WPF.Controls</RootNamespace>

    <!-- NuGet Package Metadata -->
    <GeneratePackageOnBuild Condition="'$(Configuration)' == 'Release'">true</GeneratePackageOnBuild>
    <PackageId>Fateblade.Alexandria.UI.WPF.Controls</PackageId>
    <VersionPrefix>1.0.0</VersionPrefix>
    <Authors>Fateblade</Authors>
    <Company>Fateblade</Company>
    <Product>Alexandria</Product>
    <Description>WPF custom controls for Alexandria UI</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Fonts\Apple-Chancery-Regular.ttf" />
    <None Remove="Resources\Fonts\Baskervville-Regular.ttf" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Themes\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MahApps.Metro" Version="2.4.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Base\Alexandria.UI.WPF.Base.csproj" />
    <ProjectReference Include="..\Converters\Alexandria.UI.WPF.Converters.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Fonts\Apple-Chancery-Regular.ttf" />
    <Resource Include="Resources\Fonts\Baskervville-Regular.ttf" />
  </ItemGroup>

</Project>

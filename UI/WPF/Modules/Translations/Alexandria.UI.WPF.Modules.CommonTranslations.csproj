    <RootNamespace>Fateblade.Alexandria.UI.WPF.Modules.CommonTranslations</RootNamespace>
    <AssemblyName>Alexandria.UI.WPF.Modules.CommonTranslations</AssemblyName>

    <!-- NuGet Package Metadata -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>Fateblade.Alexandria.UI.WPF.Modules.CommonTranslations</PackageId>
    <Version>1.0.0</Version>
    <Authors>Fateblade</Authors>
    <Company>Fateblade</Company>
    <Product>Alexandria</Product>
    <Description>Common translations module for Alexandria UI</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
